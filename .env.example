# ─── Exchange ──────────────────────────────────────────────────────────────────
OKX_API_KEY=your_okx_api_key
OKX_API_SECRET=your_okx_api_secret
OKX_PASSPHRASE=your_okx_passphrase
# OKX EU endpoint — not the global one
OKX_BASE_URL=https://www.okx.com

# ─── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── Telegram alerts ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=trader
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=trader_v5
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Freqtrade (Module A) ──────────────────────────────────────────────────────
FREQTRADE_BOT_NAME=trader_v5_module_a

# ─── Module B: Funding Arb ────────────────────────────────────────────────────
# Funding rate threshold annualized (e.g. 0.0005 = 0.05% per 8h = ~21% APY)
MODULE_B_FUNDING_THRESHOLD=0.0005
# Max capital share per pair (0.25 = 25% of module B capital)
MODULE_B_MAX_PAIR_SHARE=0.25
# Delta drift tolerance before rebalance (0.005 = 0.5%)
MODULE_B_DELTA_TOLERANCE=0.005
# Number of consecutive negative funding periods before exit
MODULE_B_NEGATIVE_FUNDING_N=3

# ─── Risk / Circuit Breaker ───────────────────────────────────────────────────
# Portfolio-level drawdown hard stop (0.15 = 15%)
CIRCUIT_BREAKER_DRAWDOWN=0.15
# Warning alert threshold
CIRCUIT_BREAKER_WARNING=0.10
# Module A daily drawdown limit
MODULE_A_DAILY_DRAWDOWN=0.03
# Risk per trade as fraction of module A capital
MODULE_A_RISK_PER_TRADE=0.01

# ─── Claude Overlay ───────────────────────────────────────────────────────────
# Sentiment threshold below which position size is halved
OVERLAY_SENTIMENT_THRESHOLD=-0.5
# Overlay schedule: cron expression (default: daily at 06:00 UTC)
OVERLAY_CRON=0 6 * * *
