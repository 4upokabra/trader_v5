{
  "title": "Trader V5 — Overview",
  "uid": "trader_v5_overview",
  "schemaVersion": 39,
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "title": "Total Equity (USDC)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{
        "datasource": "trader_v5_postgres",
        "rawSql": "SELECT recorded_at AS time, total_equity AS value FROM equity_snapshots ORDER BY recorded_at DESC LIMIT 1",
        "format": "table"
      }]
    },
    {
      "id": 2,
      "title": "Current Drawdown %",
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.10},
              {"color": "red", "value": 0.15}
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{
        "datasource": "trader_v5_postgres",
        "rawSql": "SELECT recorded_at AS time, drawdown_pct AS value FROM equity_snapshots ORDER BY recorded_at DESC LIMIT 1",
        "format": "table"
      }]
    },
    {
      "id": 3,
      "title": "Equity Curve",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 4},
      "targets": [{
        "datasource": "trader_v5_postgres",
        "rawSql": "SELECT recorded_at AS time, total_equity, module_a_equity, module_b_equity FROM equity_snapshots WHERE $__timeFilter(recorded_at) ORDER BY recorded_at",
        "format": "time_series"
      }]
    },
    {
      "id": 4,
      "title": "Module B — Active Positions",
      "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [{
        "datasource": "trader_v5_postgres",
        "rawSql": "SELECT pair, spot_size, perp_size, entry_spot_px, funding_collected, opened_at FROM module_b_positions WHERE status = 'open' ORDER BY opened_at DESC",
        "format": "table"
      }]
    },
    {
      "id": 5,
      "title": "Claude Overlay — Last 24h",
      "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [{
        "datasource": "trader_v5_postgres",
        "rawSql": "SELECT pair, sentiment, anomaly_flag, action, confidence, created_at FROM overlay_log WHERE created_at >= NOW() - INTERVAL '24 hours' ORDER BY created_at DESC",
        "format": "table"
      }]
    },
    {
      "id": 6,
      "title": "Funding Rates — Last 24h",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 20},
      "targets": [{
        "datasource": "trader_v5_postgres",
        "rawSql": "SELECT recorded_at AS time, pair, funding_rate FROM funding_rates WHERE $__timeFilter(recorded_at) ORDER BY recorded_at",
        "format": "time_series"
      }]
    },
    {
      "id": 7,
      "title": "System Events",
      "type": "table",
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 28},
      "targets": [{
        "datasource": "trader_v5_postgres",
        "rawSql": "SELECT occurred_at, source, level, message FROM system_events WHERE $__timeFilter(occurred_at) ORDER BY occurred_at DESC LIMIT 50",
        "format": "table"
      }]
    }
  ]
}
